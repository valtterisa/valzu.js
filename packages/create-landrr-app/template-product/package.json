{
  "name": "my-landrr-app",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun server.js",
    "build": "pnpm run build:client && pnpm run build:server",
    "build:client": "vite build --ssrManifest --outDir dist/client",
    "build:server": "vite build --ssr src/server-modules.ts --outDir dist/server",
    "preview": "cross-env NODE_ENV=production bun server.js"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "@landrr/core": "workspace:*",
    "@landrr/blocks": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "cross-env": "^7.0.3",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/vite": "^4.0.0"
  }
}
