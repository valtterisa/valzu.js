{
  "name": "@landrr/core",
  "version": "7.0.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "require": "./dist/client.cjs"
    },
    "./seo": {
      "types": "./dist/seo.d.ts",
      "import": "./dist/seo.js",
      "require": "./dist/seo.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/server.ts src/client.ts src/seo.tsx --format cjs,esm --dts --sourcemap --clean --external react --external react-dom --external vite --external elysia --external mime-types",
    "dev": "tsup src/index.ts src/server.ts src/client.ts src/seo.tsx --format cjs,esm --dts --sourcemap --clean --external react --external react-dom --external vite --external elysia --external mime-types --watch"
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "dependencies": {
    "elysia": "^1.4.10",
    "mime-types": "^3.0.1"
  },
  "devDependencies": {
    "@types/mime-types": "^3.0.1",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite": "^5.0.12",
    "tsup": "^8.3.5",
    "typescript": "^5.3.3"
  }
}
